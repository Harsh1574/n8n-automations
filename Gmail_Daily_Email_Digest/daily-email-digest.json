      "parameters": {
        "language": "pythonNative",
        "pythonCode": "# Collect all batch summaries into one combined text\ncombined = \"\"\nfor item in _items:\n    text = item[\"json\"].get(\"text\", \"\")\n    text = text.replace(\"\\\\n\", \"\\n\")\n    combined += text + \"\\n\\n---\\n\\n\"\n\nreturn [{\"json\": {\"combined_summaries\": combined}}]"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
