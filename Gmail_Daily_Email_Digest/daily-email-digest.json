        "language": "pythonNative",
        "pythonCode": "# import json\n\n# Step 1: Extract only the fields we need from each email\nemails = []\nfor item in _items:\n    emails.append({\n        \"id\": item[\"json\"].get(\"id\", \"\"),\n        \"from\": item[\"json\"].get(\"From\", \"\"),\n        \"subject\": item[\"json\"].get(\"Subject\", \"\"),\n        \"body\": item[\"json\"].get(\"snippet\", \"\")\n    })\n\n# Step 2: Split emails into batches of 10\nbatch_size = 10\nbatches = [emails[i:i+batch_size] for i in range(0, len(emails), batch_size)]\n\n# Step 3: Return each batch as a separate item\nresult = []\nfor batch in batches:\n    result.append({\n        \"json\": {\n            \"batch\": str(batch),\n            \"batch_size\": len(batch)\n        }\n    })\n\nreturn result"
      },
