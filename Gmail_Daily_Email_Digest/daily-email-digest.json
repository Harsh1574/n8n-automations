      "id": "276c83d5-0448-41d7-b827-b7dfa0f248b1",
      "name": "Code in Python1"
    },
    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "text = _items[0][\"json\"].get(\"text\", \"\")\n\n# Try both escaped and real newlines\nif \"\\\\n\" in text:\n    lines = text.split(\"\\\\n\")\nelse:\n    lines = text.split(\"\\n\")\n\nhtml = \"<table border='1' cellpadding='8' cellspacing='0' style='border-collapse:collapse; width:100%; font-family:Arial;'>\"\nheader_added = False\n\nfor line in lines:\n    line = line.strip()\n    if not line or not line.startswith(\"|\"):\n        continue\n    if set(line.replace(\"|\", \"\").replace(\"-\", \"\").replace(\" \", \"\")) == set():\n        continue\n        \n    cells = [c.strip() for c in line.split(\"|\") if c.strip()]\n    if not cells:\n        continue\n    \n    if cells[0].lower() == \"sender\":\n        if header_added:\n            continue\n        header_added = True\n        html += \"<tr style='background-color:#4CAF50; color:white;'>\"\n        for cell in cells:\n            html += f\"<th style='padding:8px; border:1px solid #ddd;'>{cell}</th>\"\n        html += \"</tr>\"\n    else:\n        html += \"<tr>\"\n        for cell in cells:\n            html += f\"<td style='padding:8px; border:1px solid #ddd;'>{cell}</td>\"\n        html += \"</tr>\"\n\nhtml += \"</table>\"\n\nreturn [{\"json\": {\"htmlContent\": html}}]"
      },
